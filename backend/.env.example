# Django
SECRET_KEY=abcdefg_this_is_my_local_key_123456789_any_text_is_ok
# 로컬 개발: True / 배포: False
DEBUG=True
# 배포 시: your-app.onrender.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Render 배포 시 자동 주입 — 직접 입력 불필요)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# 프론트엔드 배포 URL (CORS 허용용)
# FRONTEND_URL=https://your-app.vercel.app

# 카카오 로컬 API (https://developers.kakao.com)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# 네이버 검색 API (https://developers.naver.com)
# 애플리케이션 > API 설정 > 검색 체크 필요
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# L40 Qwen 채점 서버 (qwen3.5:122b-1m, Ollama)
# score_server.py를 GPU 서버에서 실행 후 주소 입력
SCORE_SERVER_URL=http://YOUR_GPU_SERVER_IP:8001/score
